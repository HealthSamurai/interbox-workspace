# Copy to .env and fill in. docker compose reads this file automatically.
# .env is gitignored — never commit real tokens.

# ── Required: one GitHub token ───────────────────────────────────────────────
# A single GitHub token with the read:packages scope authenticates BOTH:
#   • the private @healthsamurai/interbox SDK  (npm    → npm.pkg.github.com)
#   • the interbox image, if pulled privately  (docker → ghcr.io)
# Issue one with the scope pre-selected:
#   https://github.com/settings/tokens/new?description=Interbox+workspace&scopes=read:packages
# The .npmrc here reads it for `bun install`. If the image is PRIVATE, also run
# once (Docker can't read the token at pull time — the daemon must be logged in):
#   echo "$GITHUB_TOKEN" | docker login ghcr.io -u YOUR_GH_USERNAME --password-stdin
GITHUB_TOKEN=

# ── License (pick ONE path) ──────────────────────────────────────────────────
# The image is licensed: the pipeline is PAUSED until a valid interbox license is
# present. Either:
#   (a) paste an interbox license JWT here (from the Aidbox portal), or
#   (b) leave blank and click through the dashboard's activation screen at
#       http://localhost:3001 (portal OAuth) — the engine picks it up live.
INTERBOX_LICENSE=

# ── Aidbox (pipeline sender target) ──────────────────────────────────────────
# Free dev license JWT from the Aidbox portal. Without it the aidbox service
# won't start and the pipeline's sender has nowhere to deliver.
AIDBOX_LICENSE=
# Shared secret for the root client (any value; keep it consistent).
AIDBOX_SECRET=secret

# ── Image version ────────────────────────────────────────────────────────────
# Interbox engine version (image tag). `edge` = latest main build; pin a release
# like `1.4.0` for stability. To update the engine: change this, then
#   docker compose pull interbox && docker compose up -d interbox
# In the dev image the SDK ships inside the image, so this tag pins engine + SDK
# together — keep your package.json @healthsamurai/interbox pin in the same range.
INTERBOX_VERSION=edge
# Optional: point at a mirror/private registry (default ghcr.io/healthsamurai).
# INTERBOX_REGISTRY=ghcr.io/healthsamurai
# (Private GHCR package → `docker login ghcr.io` with GITHUB_TOKEN first; see above.)
