# Copy to .env and fill in. docker compose reads this file automatically.
# .env is gitignored — never commit real secrets.

# ── License (pick ONE path) ──────────────────────────────────────────────────
# The image is licensed: the pipeline is PAUSED until a valid interbox license is
# present. Either:
#   (a) paste an interbox license JWT here (from the Aidbox portal), or
#   (b) leave blank and click through the dashboard's activation screen at
#       http://localhost:3001 (portal OAuth) — the engine picks it up live.
INTERBOX_LICENSE=

# ── Aidbox (pipeline sender target) ──────────────────────────────────────────
# Leave blank to boot Aidbox unlicensed and activate it from the dashboard (Sign
# in with your Health Samurai account) — the compose entrypoint strips a blank
# value so Aidbox starts in activation mode instead of crashing. Or paste a free
# dev license JWT from the Aidbox portal here to skip the in-dashboard step.
AIDBOX_LICENSE=
# Shared secret for the root client (any value; keep it consistent).
AIDBOX_SECRET=secret

# ── Dashboard assistant (Claude Code over ACP) ───────────────────────────────
# Optional — leave blank and the dashboard still works, the assistant just can't
# answer. The container has no ~/.claude, so the subscription reaches the agent as
# a token: on a host with Claude Code + a Pro/Max subscription run
#   claude setup-token
# and paste the token below — it bills the SUBSCRIPTION, not per-token API usage.
CLAUDE_CODE_OAUTH_TOKEN=
# Alternative: pay-per-token API billing instead of the subscription.
# ANTHROPIC_API_KEY=sk-ant-...
# Third option (dev, Linux/Windows hosts): skip the token and bind-mount your host
# Claude Code login — uncomment the ~/.claude volume on the interbox service in
# docker-compose.yaml. macOS keeps creds in the Keychain, so use the token there.

# ── Image version ────────────────────────────────────────────────────────────
# Interbox engine version (image tag), pinned to a released version for a
# reproducible, matched engine+SDK pair. Use `edge` for the latest main build
# instead. To update the engine: change this, then
#   docker compose pull interbox && docker compose up -d interbox
# In the dev image the SDK ships inside the image, so this tag pins engine + SDK
# together — keep your package.json @health-samurai/interbox pin in the same range.
INTERBOX_VERSION=1.1.2
# Optional: point at a mirror/private registry (default Docker Hub, healthsamurai
# org — no host prefix needed, same as healthsamurai/aidboxone above).
# INTERBOX_REGISTRY=healthsamurai
# If pulling a private mirror: `docker login` with that registry's own
# credentials first.
